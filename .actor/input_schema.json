{
    "$schema": "https://apify.com/schemas/v1/input.ide.json",
    "title": "Face AI Scraper Input",
    "type": "object",
    "schemaVersion": 1,
    "properties": {
        "imageUpload": {
            "title": "Upload Image",
            "type": "array",
            "description": "Alternatively, upload image files directly.",
            "editor": "fileupload",
            "prefill": []
        },
        "imageUrls": {
            "title": "Image URLs",
            "type": "array",
            "description": "URLs of images you want to search.",
            "editor": "requestListSources",
            "prefill": []
        },
        "proxyConfiguration": {
            "title": "Proxy Configuration",
            "type": "object",
            "description": "Proxy settings (keep backend anonymous)",
            "editor": "proxy",
            "default": {
                "useApifyProxy": true,
                "apifyProxyGroups": [
                    "RESIDENTIAL"
                ]
            }
        }
    }
}